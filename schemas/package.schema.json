{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://carton.dev/schemas/package.schema.json",
  "title": "Carton Package Metadata",
  "description": "Carton パッケージの package.json スキーマ (v4.0). この package.json が entry_point / maya_versions / icon の SoT",
  "type": "object",
  "required": ["name", "display_name", "version", "description", "author", "maya_versions", "entry_point"],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["4.0"],
      "description": "スキーマバージョン。省略可 (Carton が読むときに 4.0 を仮定)"
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,31}$",
      "description": "パッケージの名前空間。publish 時に必須。小文字英数字+ハイフン、2〜32文字"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{1,31}$",
      "description": "import 名 / フォルダ名（小文字英数字+アンダースコア/ハイフン）"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "description": "UI表示名"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "セマンティックバージョン (MAJOR.MINOR.PATCH)"
    },
    "type": {
      "type": "string",
      "enum": ["python_package", "mel_script", "plugin", "maya_module"],
      "default": "python_package",
      "description": "パッケージタイプ。省略時は python_package"
    },
    "description": {
      "type": "string",
      "description": "ツールの説明文"
    },
    "author": {
      "type": "string",
      "description": "作者名"
    },
    "maya_versions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^\\d{4}$"
      },
      "minItems": 1,
      "description": "対応Mayaバージョン（例: [\"2024\", \"2025\", \"2026\"]）。Source of Truth — publish 時に registry にコピーされる"
    },
    "entry_point": {
      "oneOf": [
        { "$ref": "#/$defs/entry_point_python" },
        { "$ref": "#/$defs/entry_point_mel" },
        { "$ref": "#/$defs/entry_point_plugin" },
        {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_.]*:[a-zA-Z_][a-zA-Z0-9_]*$",
          "description": "後方互換: \"module:function\" 形式（内部で python 形式に変換）"
        }
      ],
      "description": "タイプ別エントリポイント。Source of Truth — registry にも preview としてコピーされるが、起動時は zip 内 package.json が優先される"
    },
    "platform": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["win64", "linux", "mac"]
      },
      "description": "対応プラットフォーム（plugin 時に必要）"
    },
    "icon": {
      "type": ["string", "null"],
      "description": "アイコン。画像ファイルの相対パス (例: resources/icon.png)、絵文字 (例: 📷)、'@auto' (icons/<name>.png 自動解決)、null (アイコン無し)"
    },
    "home_origin": {
      "type": "object",
      "description": "v5.0 本籍 origin。embedded（従来の registry）/ github / url / local を統一形で表現。別 catalogue に publish しようとすると警告される",
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "embedded" },
            "catalogue_name": { "type": "string" },
            "catalogue_id": {
              "type": "string",
              "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
            },
            "hint": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "repo"],
          "properties": {
            "type": { "const": "github" },
            "repo": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*/[A-Za-z0-9][A-Za-z0-9_.-]*$",
              "description": "GitHub owner/name"
            },
            "ref": { "type": "string", "description": "tag / branch hint (optional)" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "url"],
          "properties": {
            "type": { "const": "url" },
            "url": { "type": "string", "format": "uri" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "path"],
          "properties": {
            "type": { "const": "local" },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "source_path": {
      "type": "string",
      "description": "publish 時の source ディレクトリ絶対パス。同じマシンで再 install したときに My Tools 双方向リンクを自動復帰するためのヒント"
    },
    "is_folder": {
      "type": "boolean",
      "description": "publish 時に記録される、source がフォルダかファイルかの区別"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" }
        }
      },
      "description": "他パッケージへの依存"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "検索・分類用タグ"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "type": { "const": "plugin" } },
        "required": ["type"]
      },
      "then": {
        "required": ["platform"]
      }
    }
  ],
  "$defs": {
    "entry_point_python": {
      "type": "object",
      "required": ["type", "module", "function"],
      "properties": {
        "type": { "const": "python" },
        "module": {
          "type": "string",
          "description": "import するモジュール名"
        },
        "function": {
          "type": "string",
          "description": "呼び出す関数名"
        }
      },
      "additionalProperties": false
    },
    "entry_point_mel": {
      "type": "object",
      "required": ["type", "script", "procedure"],
      "properties": {
        "type": { "const": "mel" },
        "script": {
          "type": "string",
          "pattern": "\\.mel$",
          "description": "source するMELスクリプトファイル名"
        },
        "procedure": {
          "type": "string",
          "description": "呼び出すMELプロシージャ名"
        }
      },
      "additionalProperties": false
    },
    "entry_point_plugin": {
      "type": "object",
      "required": ["type", "plugin_file"],
      "properties": {
        "type": { "const": "plugin" },
        "plugin_file": {
          "type": "string",
          "description": "プラグインファイル名（拡張子なし）"
        },
        "commands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "プラグインが提供するコマンド"
        },
        "nodes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "プラグインが提供するノードタイプ"
        },
        "ui_command": {
          "type": "string",
          "description": "UI起動コマンド（UI有りの場合）"
        },
        "auto_load": {
          "type": "boolean",
          "default": false,
          "description": "Maya起動時に自動ロードするか"
        }
      },
      "additionalProperties": false
    }
  }
}
