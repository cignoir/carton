{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://carton.dev/schemas/registry.schema.json",
  "title": "Carton Registry",
  "description": "Carton パッケージレジストリ (v3.0 — namespace/name キー)",
  "type": "object",
  "required": ["schema_version", "packages"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "3.0"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "最終更新日時 (ISO 8601)"
    },
    "packages": {
      "type": "object",
      "description": "キーは \"<namespace>/<name>\" 形式",
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9-]{1,31}/[a-z0-9][a-z0-9_-]{1,31}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/registry_package"
      }
    }
  },
  "$defs": {
    "registry_package": {
      "type": "object",
      "required": ["namespace", "name", "display_name", "type", "description", "author", "latest_version", "versions"],
      "properties": {
        "namespace": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,31}$"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{1,31}$"
        },
        "display_name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["python_package", "mel_script", "plugin"]
        },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "first_published_by": {
          "type": "string",
          "description": "最初に publish した author。以後の publish で author が変わると警告される"
        },
        "first_published_at": {
          "type": "string",
          "format": "date-time"
        },
        "platform": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["win64", "linux", "mac"]
          }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "icon": {
          "description": "true なら icons/<name>.png を参照、文字列なら絵文字または直接パス",
          "oneOf": [
            { "type": "boolean" },
            { "type": "string" }
          ]
        },
        "latest_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "versions": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/version_entry"
          }
        }
      }
    },
    "version_entry": {
      "type": "object",
      "required": ["maya_versions", "released_at"],
      "properties": {
        "maya_versions": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "download_url": {
          "type": "string",
          "description": "registry.json からの相対パス"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "非プラグインパッケージ用のSHA256ハッシュ"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "platform": {
          "type": "array",
          "items": { "type": "string" }
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/artifact"
          },
          "description": "プラグイン用: プラットフォーム×Mayaバージョン別のアーティファクト"
        },
        "released_at": {
          "type": "string",
          "format": "date-time"
        },
        "changelog": {
          "type": "string"
        }
      }
    },
    "artifact": {
      "type": "object",
      "required": ["sha256", "size_bytes"],
      "properties": {
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
