{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://carton.dev/schemas/registry.schema.json",
  "title": "Carton Registry",
  "description": "Carton パッケージレジストリ (v4.0). registry_id 必須、entry_point は preview hint、icon は string|null",
  "type": "object",
  "required": ["schema_version", "registry_id", "packages"],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["4.0"]
    },
    "registry_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
      "description": "レジストリの不変識別子 (UUID v4)。ローカルとリモートミラーの同一性判定に使用"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "最終更新日時 (ISO 8601)"
    },
    "packages": {
      "type": "object",
      "description": "キーは \"<namespace>/<name>\" 形式",
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9-]{1,31}/[a-z0-9][a-z0-9_-]{1,31}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/registry_package"
      }
    }
  },
  "$defs": {
    "registry_package": {
      "type": "object",
      "required": ["namespace", "name", "display_name", "type", "description", "author", "latest_version", "versions"],
      "properties": {
        "namespace": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,31}$"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{1,31}$"
        },
        "display_name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["python_package", "mel_script", "plugin", "maya_module"]
        },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "first_published_by": {
          "type": "string",
          "description": "最初に publish した author。以後の publish で author が変わると警告される"
        },
        "first_published_at": {
          "type": "string",
          "format": "date-time"
        },
        "platform": {
          "type": "array",
          "description": "パッケージ全体のデフォルト対応プラットフォーム。version_entry.platform で version 単位に override 可能",
          "items": {
            "type": "string",
            "enum": ["win64", "linux", "mac"]
          }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "icon": {
          "description": "アイコン。文字列 (絵文字またはファイル名) または null。'@auto' は icons/<name>.png を意味する",
          "type": ["string", "null"]
        },
        "entry_point": {
          "type": "object",
          "description": "Preview hint — カード UI が install 前に Launch/Activate を判定するためのコピー。SoT は zip 内の package.json。publisher により latest_version の package.json から自動転写される。"
        },
        "latest_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "versions": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/version_entry"
          }
        }
      }
    },
    "version_entry": {
      "type": "object",
      "required": ["maya_versions", "released_at"],
      "properties": {
        "maya_versions": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "このバージョンが対応する Maya バージョン。package.json の maya_versions が SoT"
        },
        "download_url": {
          "type": "string",
          "description": "registry.json からの相対パス"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "非プラグインパッケージ用のSHA256ハッシュ (verified badge の SoT)"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "platform": {
          "type": "array",
          "description": "version 単位の override。指定がなければ registry_package.platform を継承",
          "items": {
            "type": "string",
            "enum": ["win64", "linux", "mac"]
          }
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/artifact"
          },
          "description": "プラグイン用: プラットフォーム×Mayaバージョン別のアーティファクト"
        },
        "released_at": {
          "type": "string",
          "format": "date-time"
        },
        "changelog": {
          "type": "string"
        }
      }
    },
    "artifact": {
      "type": "object",
      "required": ["sha256", "size_bytes"],
      "properties": {
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
